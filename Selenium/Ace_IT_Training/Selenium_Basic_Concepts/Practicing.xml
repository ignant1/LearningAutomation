<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org">
<!-- Change parallel to "none" if you want to run browsers one after another -->
<suite name="Cross Browser Suite" parallel="tests" thread-count="3">
    
    <!-- Test execution on Chrome -->
    <test name="Chrome Test">
        <parameter name="browser" value="chrome"/>
        <classes>
            <class name="selenium.BrowserSetup"/>
            <class name="selenium.MultiBrowser"/>
        </classes>
    </test>
    
    <!-- Test execution on Firefox -->
    <test name="Firefox Test">
        <parameter name="browser" value="firefox"/>
        <classes>
            <class name="selenium.BrowserSetup"/>
            <class name="selenium.MultiBrowser"/>
        </classes>
    </test>
    
    <!-- Test execution on Edge -->
    <test name="Edge Test">
        <parameter name="browser" value="edge"/>
        <classes>
            <class name="selenium.BrowserSetup"/>
            <class name="selenium.MultiBrowser"/>
        </classes>
    </test>
    
</suite>